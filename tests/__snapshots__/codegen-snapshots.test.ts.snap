 * Build a typed viem contract instance for TestToken.
 *
 * @example
 *   const testToken = createTestTokenContract('0x...', publicClient)
 *   const value = await testToken.read.someMethod()
 */
export function createTestTokenContract(address: Address, client: Client) {
  return getContract({ address, abi: TEST_TOKEN_ABI, client })
}
